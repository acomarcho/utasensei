{
	"name": "utasensei-workspace",
	"private": true,
	"version": "1.0.0",
	"scripts": {
		"cli": "pnpm --filter @utasensei/cli exec tsx src/index.ts",
		"studio": "pnpm --filter @utasensei/ai-studio-prototype dev",
		"build": "pnpm -r --if-present build",
		"typecheck": "pnpm -r --if-present typecheck",
		"lint": "biome lint .",
		"lint:fix": "biome lint . --write",
		"format": "biome format . --write",
		"db:generate:cli": "pnpm --filter @utasensei/cli db:generate",
		"db:push:cli": "pnpm --filter @utasensei/cli db:push",
		"db:generate:web-app": "pnpm --filter ./apps/web-app db:generate",
		"db:push:web-app": "pnpm --filter ./apps/web-app db:push",
		"prepare": "lefthook install",
		"web-app": "pnpm --filter ./apps/web-app dev"
	},
	"engines": {
		"node": ">=22.0.0",
		"pnpm": ">=10.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.5",
		"lefthook": "^2.1.2"
	}
}
