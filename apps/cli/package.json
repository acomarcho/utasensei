{
	"name": "@utasensei/cli",
	"private": true,
	"version": "1.0.0",
	"description": "UtaSensei command-line tools",
	"main": "dist/index.js",
	"bin": {
		"utasensei": "dist/index.js"
	},
	"scripts": {
		"cli": "tsx src/index.ts",
		"dev": "tsx src/index.ts",
		"build": "tsc -p tsconfig.json",
		"start": "node dist/index.js",
		"db:generate": "drizzle-kit generate --config drizzle.config.ts",
		"db:push": "drizzle-kit push --config drizzle.config.ts",
		"typecheck": "tsc -p tsconfig.json --noEmit"
	},
	"dependencies": {
		"@ai-sdk/fireworks": "^2.0.36",
		"@libsql/client": "^0.17.0",
		"ai": "^6.0.105",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.1",
		"playwright": "^1.55.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^25.3.2",
		"drizzle-kit": "^0.31.9",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
