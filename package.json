		"drizzle-kit": "^0.31.9",
		"lefthook": "^2.1.2",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	},
	"dependencies": {
		"@ai-sdk/fireworks": "^2.0.36",
		"@libsql/client": "^0.17.0",
		"ai": "^6.0.105",
		"dotenv": "^17.3.1",
